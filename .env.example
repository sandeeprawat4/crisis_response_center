# Crisis Response Center - Environment Configuration Template
# Copy this file to .env and fill in your values

# Google Gemini API Key (REQUIRED)
GOOGLE_API_KEY=your_api_key_here

# ERP MCP Server Configuration (Optional - defaults shown)
# Customize these for different environments (dev, staging, production)

# Server Host - defaults to localhost
ERP_SERVER_HOST=127.0.0.1

# Server Port - defaults to 8000
ERP_SERVER_PORT=8000

# Full Server URL - overrides host/port if set
# ERP_SERVER_URL=http://127.0.0.1:8000

# Usage examples for different environments:
#
# Development (default):
#   ERP_SERVER_HOST=127.0.0.1
#   ERP_SERVER_PORT=8000
#
# Remote development server:
#   ERP_SERVER_HOST=dev-server.example.com
#   ERP_SERVER_PORT=8000
#
# Production with custom port:
#   ERP_SERVER_HOST=erp-prod.example.com
#   ERP_SERVER_PORT=443
#   ERP_SERVER_URL=https://erp-prod.example.com
#
# Load balanced production:
#   ERP_SERVER_URL=https://erp-api.example.com/v1
